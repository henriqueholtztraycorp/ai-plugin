{
  "name": "wake-commerce-mcp",
  "version": "1.0.0",
  "description": "CLI for Wake Commerce",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "wake-commerce": "./dist/index.js",
    "wc": "./dist/index.js",
    "wake-commerce-mcp": "./dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src api",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "pretest": "npm run build",
    "test": "node --test \"tests/*.test.js\""
  },
  "keywords": [
    "cli",
    "commerce",
    "wake"
  ],
  "author": "Wake Commerce",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.10.0",
    "@vercel/node": "^5.7.4",
    "eslint": "^10.0.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1"
  },
  "files": [
    "dist"
  ]
}
